  },
  {
    "globalSectionId": 2,
    "title": "3",
    "content": "In this Act, unless the context otherwise requires",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/3.php?Title=Right%20to%20Information%20Act,%202005&STitle=In%20this%20Act,%20unless%20the%20context%20otherwise%20requires"
  },
  {
    "globalSectionId": 0,
    "title": "Chapter II",
    "content": "Right to information and obligations of public authorities",
    "link": ""
  },
  {
    "globalSectionId": 3,
    "title": "4",
    "content": "Subject to the provisions of this Act, all citizens shall have the right to information",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/4.php?Title=Right%20to%20Information%20Act,%202005&STitle=Subject%20to%20the%20provisions%20of%20this%20Act,%20all%20citizens%20shall%20have%20the%20right%20to%20information"
  },
  {
    "globalSectionId": 4,
    "title": "5",
    "content": "Every public authority shall, within one hundred days of the enactment of this Act",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/5.php?Title=Right%20to%20Information%20Act,%202005&STitle=Every%20public%20authority%20shall,%20within%20one%20hundred%20days%20of%20the%20enactment%20of%20this%20Act"
  },
  {
    "globalSectionId": 5,
    "title": "6",
    "content": "A person, who desires to obtain any information under this Act",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/6.php?Title=Right%20to%20Information%20Act,%202005&STitle=A%20person,%20who%20desires%20to%20obtain%20any%20information%20under%20this%20Act"
  },
  {
    "globalSectionId": 6,
    "title": "7",
    "content": "Notwithstanding anything contained in this Act, there shall be no obligation to give any citizen",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/7.php?Title=Right%20to%20Information%20Act,%202005&STitle=Notwithstanding%20anything%20contained%20in%20this%20Act,%20there%20shall%20be%20no%20obligation%20to%20give%20any%20citizen"
  },
  {
    "globalSectionId": 0,
    "title": "Chapter III",
    "content": "The Central Information Commission",
    "link": ""
  },
  {
    "globalSectionId": 7,
    "title": "8",
    "content": "The Central Information Commission",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/8.php?Title=Right%20to%20Information%20Act,%202005&STitle=The%20Central%20Information%20Commission"
  },
  {
    "globalSectionId": 8,
    "title": "9",
    "content": "The Chief Information Commissioner shall hold office for a term of five years from the date on which he enters upon his office and shall not be eligible for reappointment:",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/9.php?Title=Right%20to%20Information%20Act,%202005&STitle=The%20Chief%20Information%20Commissioner%20shall%20hold%20office%20for%20a%20term%20of%20five%20years%20from%20the%20date%20on%20which%20he%20enters%20upon%20his%20office%20and%20shall%20not%20be%20eligible%20for%20reappointment:"
  },
  {
    "globalSectionId": 0,
    "title": "Chapter IV",
    "content": "The State Information Commission",
    "link": ""
  },
  {
    "globalSectionId": 9,
    "title": "10",
    "content": "The State Information Commission",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/10.php?Title=Right%20to%20Information%20Act,%202005&STitle=The%20State%20Information%20Commission"
  },
  {
    "globalSectionId": 10,
    "title": "11",
    "content": "The State Chief Information Commissioner shall hold office for a term of five years from the date on which he enters upon his office and shall not be eligible for reappointment",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/11.php?Title=Right%20to%20Information%20Act,%202005&STitle=The%20State%20Chief%20Information%20Commissioner%20shall%20hold%20office%20for%20a%20term%20of%20five%20years%20from%20the%20date%20on%20which%20he%20enters%20upon%20his%20office%20and%20shall%20not%20be%20eligible%20for%20reappointment"
  },
