    "globalSectionId": 0,
    "title": "Chapter VI",
    "content": "Miscellaneous",
    "link": ""
  },
  {
    "globalSectionId": 12,
    "title": "13",
    "content": "No suit, prosecution or other legal proceeding shall lie against any person for anything which is in good faith done or intended to be done under this Act or any rule made thereunder",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/13.php?Title=Right%20to%20Information%20Act,%202005&STitle=No%20suit,%20prosecution%20or%20other%20legal%20proceeding%20shall%20lie%20against%20any%20person%20for%20anything%20which%20is%20in%20good%20faith%20done%20or%20intended%20to%20be%20done%20under%20this%20Act%20or%20any%20rule%20made%20thereunder"
  },
  {
    "globalSectionId": 13,
    "title": "14",
    "content": "The appropriate Government may, to the extent of availability of financial and other resources",
    "link": "https://www.advocatekhoj.com/library/bareacts/righttoinformation/14.php?Title=Right%20to%20Information%20Act,%202005&STitle=The%20appropriate%20Government%20may,%20to%20the%20extent%20of%20availability%20of%20financial%20and%20other%20resources"
  },
